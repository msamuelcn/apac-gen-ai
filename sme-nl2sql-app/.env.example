# AlloyDB connection  (use AlloyDB Auth Proxy for local dev)
ALLOYDB_HOST=127.0.0.1
ALLOYDB_PORT=5432
ALLOYDB_DB=sme_demo
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=changeme
ALLOYDB_SSLMODE=require

# Connection pool
DB_POOL_MAX=5

# Vertex AI (NL to SQL)
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
GEMINI_MODEL=gemini-2.0-flash

# Flask
PORT=8080
