# ============================================================================
# SME NL2SQL Application Configuration
#
# Copy this file to .env and fill in your values.
# For local development, use AlloyDB Auth Proxy to forward connections.
# For Cloud Run, use Private IP or use Auth Proxy as sidecar container.
# ============================================================================

# ---------------------------------------------------------------------------
# ALLOYDB CONNECTION PARAMETERS
# ---------------------------------------------------------------------------
# Host: Use 127.0.0.1:5432 if running AlloyDB Auth Proxy locally
#       Use private IP (e.g., 10.0.0.5) on Cloud Run with Private Service Connect
ALLOYDB_HOST=127.0.0.1
ALLOYDB_PORT=5432

# Database name where you initialized the schema (see sql/init.sql)
ALLOYDB_DB=postgres

# Database user and password
# SECURITY: Use IAM authentication on Cloud Run when possible
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=changeme

# SSL mode: 'require' for production, 'disable' only for local testing
ALLOYDB_SSLMODE=require

# ---------------------------------------------------------------------------
# CONNECTION POOL CONFIGURATION
# ---------------------------------------------------------------------------
# Maximum number of database connections in the pool.
# Tune based on concurrency:
#   - Local dev: 2-5
#   - Small deployment (Cloud Run 1 instance): 5-10
#   - High concurrency: 20-50
DB_POOL_MAX=5

# ---------------------------------------------------------------------------
# GOOGLE CLOUD PLATFORM (GCP) CONFIGURATION
# ---------------------------------------------------------------------------
# Project ID where AlloyDB and Vertex AI resources are provisioned
GCP_PROJECT=your-gcp-project-id

# Region for Vertex AI API calls (should match AlloyDB region)
# Examples: us-central1, us-east1, us-west1, asia-southeast1
GCP_REGION=us-central1

# ---------------------------------------------------------------------------
# VERTEX AI & GEMINI CONFIGURATION
# ---------------------------------------------------------------------------
# LLM model for natural-language-to-SQL generation
# Recommended: gemini-2.0-flash (fast, cost-effective, supports long context)
# Alternative: gemini-1.5-pro (higher quality, slower, more expensive)
GEMINI_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# SEMANTIC QUERY CACHE CONFIGURATION
# ---------------------------------------------------------------------------
# Embedding model for semantic similarity search via pgvector.
# Used to find cached queries similar to the current question.
# Options: text-embedding-005 (768-dim, recommended), text-embedding-004
EMBEDDING_MODEL=text-embedding-005

# Cosine similarity threshold (0.0 to 1.0) for cache hits.
# Higher = stricter matching (fewer cache hits, more Gemini calls).
# Lower = looser matching (more cache hits, risk of wrong results).
# Recommended: 0.88 (balances accuracy vs cost savings)
# Tune based on query quality feedback.
CACHE_SIMILARITY_THRESHOLD=0.88

# ---------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ---------------------------------------------------------------------------
# Flask server port. Cloud Run injects PORT env var; this is the fallback.
PORT=8080

# ============================================================================
# VALIDATION CHECKLIST
# ============================================================================
# Before deploying, verify:
# [ ] GCP_PROJECT is correct (gcloud config get-value project)
# [ ] ALLOYDB_HOST is reachable (nc -zv $ALLOYDB_HOST $ALLOYDB_PORT)
# [ ] ALLOYDB_USER/PASSWORD has credentials
# [ ] Database schema initialized (SELECT 1 FROM sme_risk.sme_financial LIMIT 1)
# [ ] pgvector extension created (SELECT * FROM pg_extension WHERE extname='vector')
# [ ] query_cache table exists (SELECT 1 FROM sme_risk.query_cache LIMIT 1)
# [ ] EMBEDDING_MODEL is available in Vertex AI (test via python scripts/setup_schema.py)
# [ ] GEMINI_MODEL is available in Vertex AI (test via curl / gcloud ai language models list)
# ============================================================================
